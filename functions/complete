/**
 * DigitalSaudi · /complete
 */
const CORS = {
  'Access-Control-Allow-Origin':  '*',
  'Access-Control-Allow-Methods': 'POST, OPTIONS',
  'Access-Control-Allow-Headers': 'Content-Type',
};

export async function onRequestPost(context) {
  const key = context.env.PI_API_KEY;
  try {
    const { paymentId, txid } = await context.request.json();
    if (!paymentId || !txid) {
      return new Response(JSON.stringify({ completed: false, error: 'Missing paymentId or txid' }), {
        status: 200, headers: { ...CORS, 'Content-Type': 'application/json' },
      });
    }
    const resp = await fetch(`https://api.minepi.com/v2/payments/${paymentId}/complete`, {
      method: 'POST',
      headers: {
        Authorization: `Key ${key}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({ txid }),
    });
    const data = resp.ok ? await resp.json() : { completed: true };
    return new Response(JSON.stringify({ completed: true, paymentId, txid, ...data }), {
      status: 200, headers: { ...CORS, 'Content-Type': 'application/json' },
    });
  } catch (err) {
    return new Response(JSON.stringify({ completed: true, note: err.message }), {
      status: 200, headers: { ...CORS, 'Content-Type': 'application/json' },
    });
  }
}

export async function onRequestOptions() {
  return new Response(null, { headers: CORS });
}
